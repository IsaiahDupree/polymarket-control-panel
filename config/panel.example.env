# Copy to panel.env (gitignored) and adjust.

# Server
PANEL_HOST=127.0.0.1
PANEL_PORT=8799

# Strategy launching (optional — read-only panel if unset)
# EDGEOS_REPO=/path/to/edgeos-repo
# EDGEOS_PYBIN=/path/to/venv/bin/python
# TRADER_CWD=/path/to/trader-cwd

# Non-US egress proxy (optional). Either point at a dir containing webshare.py
# + .env with WEBSHARE_TOKEN, or pin an explicit proxy URL.
# WEBSHARE_DIR=/path/to/dir-with-webshare.py
# WEBSHARE_COUNTRY=BR
# PANEL_PROXY=http://user:pass@host:port

# History / caching
PANEL_SNAPSHOT_SECS=60
PANEL_CACHE_TTL=5
